  {"model": "products.product", "pk": 1, "fields": {"sku": "TW-P001", "name": "Chaleco Multibolsillos Practical", "slug": "chaleco-multibolsillos-practical", "category": 1, "line": 1, "description": "Chaleco con múltiples bolsillos funcionales ideal para trabajos en terreno. Fabricado en tela 65/35 poliéster/algodón con acabado antidesgarro. Disponible con bordado corporativo a medida.", "technical_sheet": "Material: 65% Poliéster / 35% Algodón. Gramaje: 220 g/m². Cierre frontal con botones a presión. 8 bolsillos exteriores. Costuras reforzadas en puntos de tensión. Lavable a máquina 40°C.", "price": "24990", "stock": 50, "is_active": true, "is_featured": true, "has_embroidery": true, "created_at": "2026-01-01T10:00:00Z", "updated_at": "2026-01-01T10:00:00Z"}},
  {"model": "products.product", "pk": 2, "fields": {"sku": "TW-I001", "name": "Pantalón Cargo Iron Reforzado", "slug": "pantalon-cargo-iron-reforzado", "category": 1, "line": 2, "description": "Pantalón cargo de alta resistencia con refuerzos en rodillas y bolsillos de cargo laterales. Diseñado para soportar las condiciones de trabajo más exigentes.", "technical_sheet": "Material: 100% Algodón rip-stop. Gramaje: 260 g/m². Refuerzos en rodillas con costura triple. 6 bolsillos. Pretina elástica en espalda. Lavable a máquina 60°C.", "price": "34990", "stock": 40, "is_active": true, "is_featured": true, "has_embroidery": true, "created_at": "2026-01-15T10:00:00Z", "updated_at": "2026-01-15T10:00:00Z"}},
  {"model": "products.product", "pk": 3, "fields": {"sku": "TW-FA001", "name": "Polera Técnica Dry-Fit Free Action", "slug": "polera-tecnica-dry-fit-free-action", "category": 1, "line": 3, "description": "Polera técnica con tecnología dry-fit que evacúa la humedad manteniendo la piel seca. Diseño ergonómico que permite total libertad de movimiento.", "technical_sheet": "Material: 100% Poliéster microfibra. Gramaje: 150 g/m². Tecnología anti-humedad. Costuras planas. Protección UV Factor 30+. Lavable a máquina 40°C.", "price": "12990", "stock": 80, "is_active": true, "is_featured": false, "has_embroidery": true, "created_at": "2026-01-20T10:00:00Z", "updated_at": "2026-01-20T10:00:00Z"}},
